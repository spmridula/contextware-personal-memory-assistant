{
  "name": "context-ware-personal-memory-assistant",
  "version": "1.0.0",
  "private": true,
  "description": "A fully client-side face recognition and personal memory assistant",
  "dependencies": {
    "@vladmandic/face-api": "^1.7.13",
    "idb": "^8.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1"
  },
  "scripts": {
